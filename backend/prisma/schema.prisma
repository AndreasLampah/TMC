// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

//model pasien---------------------------------------------------------------------
model RegPeriksa {
  no_reg          String @db.VarChar(8)
  no_rawat        String @id @db.VarChar(17)

  tgl_registrasi  DateTime @db.Date
  jam_reg         DateTime @db.Time(0)

  kd_dokter       String @db.VarChar(20)
  no_rkm_medis    String @db.VarChar(15)
  kd_poli         String @db.Char(5)

  p_jawab         String @db.VarChar(100)
  almt_pj         String @db.VarChar(200)
  hubunganpj      String @db.VarChar(20)

  biaya_reg       Float @db.Double

  stts            StatusRegPeriksa
  stts_daftar     StatusDaftar
  status_lanjut   StatusLanjut

  kd_pj           String @db.Char(3)

  umurdaftar      Int

  sttsumur        StatusUmur
  status_bayar    StatusBayar
  status_poli     StatusPoli

  @@map("reg_periksa")
}

enum StatusRegPeriksa {
  Belum
  Sudah
  Batal
  Berkas_Diterima @map("Berkas Diterima")
  Dirujuk
  Meninggal
  Dirawat
  Pulang_Paksa    @map("Pulang Paksa")
}

enum StatusDaftar {
  DASH @map("-")
  Lama
  Baru
}

enum StatusLanjut {
  Ralan
  Ranap
}

enum StatusUmur {
  Th
  Bl
  Hr
}

enum StatusBayar {
  Sudah_Bayar @map("Sudah Bayar")
  Belum_Bayar @map("Belum Bayar")
}

enum StatusPoli {
  Lama
  Baru
}


//model igd---------------------------------------------------------------------
model DataTriaseIgd {
  no_rawat String @id @db.VarChar(17)

  tgl_kunjungan DateTime @db.DateTime

  cara_masuk CaraMasuk
  alat_transportasi AlatTransportasi
  alasan_kedatangan AlasanKedatangan

  keterangan_kedatangan String @db.VarChar(100)

  kode_kasus String @db.VarChar(3)

  tekanan_darah String @db.VarChar(8)
  nadi String @db.VarChar(3)
  pernapasan String @db.VarChar(3)
  suhu String @db.VarChar(5)
  saturasi_o2 String @db.VarChar(3)
  nyeri String @db.VarChar(5)

  @@map("data_triase_igd")
}

enum CaraMasuk {
  Jalan
  Brankar
  Kursi_Roda @map("Kursi Roda")
  Digendong
}

enum AlatTransportasi {
  DASH @map("-")
  AGD
  Sendiri
  Swasta
}

enum AlasanKedatangan {
  Datang_Sendiri @map("Datang Sendiri")
  Polisi
  Rujukan
  Bidan
  Puskesmas
  Rumah_Sakit @map("Rumah Sakit")
  Poliklinik
  Faskes_Lain @map("Faskes Lain")
  DASH @map("-")
}


//model Laboratorium---------------------------------------------------------------------

model PeriksaLab {
  no_rawat                 String   @db.VarChar(17)
  nip                      String?  @db.VarChar(20)
  kd_jenis_prw             String   @db.VarChar(15)
  tgl_periksa              DateTime @db.Date
  jam                      DateTime @db.Time(0)

  dokter_perujuk           String?  @db.VarChar(20)

  bagian_rs                Float?
  bhp                      Float?
  tarif_perujuk            Float?
  tarif_tindakan_dokter    Float?
  tarif_tindakan_petugas   Float?
  kso                      Float?
  menejemen                Float?
  biaya                    Float?

  kd_dokter                String?  @db.VarChar(20)

  status                   StatusPeriksaLab?
  kategori                 KategoriPeriksaLab?

  @@id([no_rawat, kd_jenis_prw, tgl_periksa, jam])
  @@map("periksa_lab")
}

enum StatusPeriksaLab {
  Ralan
  Ranap
}

enum KategoriPeriksaLab {
  PA
  PK
  MB
}

//model petugas---------------------------------------------------------------------

model Petugas {
  nip         String       @id @db.VarChar(20)
  nama        String       @db.VarChar(50)
  jk          JenisKelamin
  tmpLahir    String?      @map("tmp_lahir") @db.VarChar(20)
  tglLahir    DateTime?    @map("tgl_lahir") @db.Date
  golDarah    GolDarah?    @map("gol_darah")
  agama       String?      @db.VarChar(12)
  sttsNikah   StatusNikah? @map("stts_nikah")
  alamat      String?      @db.VarChar(60)
  kdJbtn      String?      @map("kd_jbtn") @db.Char(4)
  noTelp      String?      @map("no_telp") @db.VarChar(13)
  email       String?      @db.VarChar(70)
  status      StatusPetugas?

  @@map("petugas")
}

enum JenisKelamin {
  L
  P
}

enum GolDarah {
  A
  B
  O
  AB
  MINUS @map("-")
}

enum StatusNikah {
  BELUM_MENIKAH @map("BELUM MENIKAH")
  MENIKAH
  JANDA
  DUDHA
  JOMBLO
}

enum StatusPetugas {
  
  AKTIF     @map("1")
  NONAKTIF  @map("0")
}

//model kamar---------------------------------------------------------------------
model Kamar {
  kdKamar     String       @id @map("kd_kamar") @db.VarChar(15)
  kdBangsal   String       @map("kd_bangsal") @db.Char(5)
  tarifKamar  Float        @map("trf_kamar") @db.Double

  status      StatusKamar
  kelas       KelasKamar
  statusData  StatusData   @map("statusdata")

  @@map("kamar")

  @@index([status])
  @@index([kelas])
  @@index([kdBangsal])
  @@index([statusData])

  @@index([status, kelas])
  @@index([status, kdBangsal])
}

enum StatusKamar {
  ISI
  KOSONG
  DIBERSIHKAN
  DIBOOKING
  PERBAIKAN
}

enum KelasKamar {
  KELAS_1      @map("Kelas 1")
  KELAS_2      @map("Kelas 2")
  KELAS_3      @map("Kelas 3")
  KELAS_UTAMA  @map("Kelas Utama")
  KELAS_VIP    @map("Kelas VIP")
  KELAS_VVIP   @map("Kelas VVIP")
}

enum StatusData {
  NON_AKTIF @map("0")
  AKTIF     @map("1")
}